```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled files
*.o
*.obj
*.so
*.dll
*.exe
*.out

# Dependencies
.venv/
venv/
env/
pip-log.txt
pip-selfcheck.json

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Environment variables
.env
.env.local
*.env.*

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE specific
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
```