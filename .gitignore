```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
pip-log.txt
pip-selfcheck.json

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment variables
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
.coverage
htmlcov/
coverage/

# Distribution / packaging
dist/
build/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# Pytest
.pytest_cache/

# MyPy
.mypy_cache/

# SQLite database
*.db
*.db-journal

# OS generated files
.DS_Store
Thumbs.db
```